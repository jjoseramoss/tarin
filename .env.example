# Copy this file to .env and fill in your own Supabase project's values.
# Find both of these in Supabase: Project Settings -> API
#   Project URL           -> VITE_SUPABASE_URL
#   Project API keys/anon -> VITE_SUPABASE_ANON_KEY
#
# Never put real values in this file — it's committed to git.
# Real values go in .env, which is gitignored.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
